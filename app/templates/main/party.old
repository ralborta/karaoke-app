{% extends "base.html" %}

{% block title %}Party Mode{% endblock %}

{% block content %}
<div class="container">
    <div class="row mb-4">
        <div class="col">
            {% if current_user.is_admin %}
            <a href="{{ url_for('main.party_control') }}" class="btn btn-warning float-end">
                <i class="fas fa-cogs"></i> Panel de Control
            </a>
            {% endif %}
            <h2>Party Mode</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#searchModal">
                <i class="fas fa-plus"></i> Agregar Canción
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h4>Stream</h4>
                </div>
                <div class="card-body">
                    <div class="ratio ratio-16x9">
                        <iframe id="youtubePlayer" src="" frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h4>Próximos Cantantes</h4>
                </div>
                <div class="card-body">
                    <div id="songQueue">
                        {% for performance in queue %}
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6>{{ performance.song.title }}</h6>
                                <small>{{ performance.user.username }}</small>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de búsqueda -->
<div class="modal fade" id="searchModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Buscar Canción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="text" id="searchQuery" class="form-control" placeholder="Buscar canción...">
                    <button class="btn btn-primary" onclick="searchSongs()">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </div>
                <div id="searchResults"></div>
            </div>
        </div>
    </div>
</div>

{% block extra_js %}
<script>
let currentVideoId = '';

function searchSongs() {
    const query = document.getElementById('searchQuery').value;
    fetch(`/search?q=${encodeURIComponent(query)}`)
        .then(response => response.json())
        .then(data => {
            const resultsDiv = document.getElementById('searchResults');
            resultsDiv.innerHTML = '';
            data.forEach(song => {
                const songDiv = document.createElement('div');
                songDiv.className = 'card mb-2';
                songDiv.innerHTML = `
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">${song.title}</h6>
                                <p class="card-text small">${song.channel}</p>
                            </div>
                            <button onclick="addToQueue('${song.video_id}', '${song.title.replace("'", "\\'")}')" 
                                    class="btn btn-sm btn-success">
                                <i class="fas fa-plus"></i> Agregar
                            </button>
                        </div>
                    </div>
                `;
                resultsDiv.appendChild(songDiv);
            });
        });
}

function addToQueue(videoId, title) {
    fetch('/party/queue/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            video_id: videoId,
            title: title
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error al agregar la canción a la cola');
        }
    });
}

function updateQueue() {
    fetch('/party/queue')
        .then(response => response.json())
        .then(data => {
            const queueDiv = document.getElementById('songQueue');
            queueDiv.innerHTML = '';
            data.forEach(item => {
                const itemDiv = document.createElement('div');
                itemDiv.className = 'd-flex justify-content-between align-items-center mb-2';
                itemDiv.innerHTML = `
                    <div>
                        <h6>${item.song.title}</h6>
                        <small>${item.user.username}</small>
                    </div>
                `;
                queueDiv.appendChild(itemDiv);
            });
        });
}

function updatePlayer() {
    fetch('/party/current')
        .then(response => response.json())
        .then(data => {
            if (data.video_id && data.video_id !== currentVideoId) {
                currentVideoId = data.video_id;
                document.getElementById('youtubePlayer').src = 
                    `https://www.youtube.com/embed/${data.video_id}?autoplay=1&mute=0`;
            }
        });
}

setInterval(updateQueue, 5000);
setInterval(updatePlayer, 5000);
updateQueue();
updatePlayer();
</script>
{% endblock %}
{% endblock %}
